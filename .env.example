PDF_SOURCE=./papers/pdfs
TEI_XML_DIR=./papers/tei
JSON_DIR=./papers/json

# Grobid
GROBID_URL=http://localhost:8070

# TypeDB
TYPEDB_ADDRESS=localhost:1729
TYPEDB_DATABASE=kp-scepa
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=password
TYPEDB_TLS=false
TYPEDB_WIPE_DATABASE=false

# ROR (Research Organization Registry, for institution ror-id resolution)
ROR_HOST=https://api.ror.org

# Qdrant
QDRANT_URL=http://localhost:6334
QDRANT_COLLECTION=kp-scepa
QDRANT_VECTOR_SIZE=4096
QDRANT_API_KEY=
QDRANT_WIPE_COLLECTION=false

# Embedding
OPENAI_HOST=https://api.tokenfactory.nebius.com/v1/
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Studio PDF store (optional; pushes each paper's own PDF to a running
# Studio instance's /api/pdf/{sha256} store, keyed by the same SourceHash
# used everywhere else, so Studio can serve the original PDF for citations)
STUDIO_PDF_STORE_ENABLED=false
STUDIO_BASE_URL=
STUDIO_API_KEY=

# BATCH
PARALLELISM=8
WORKER_THREADS=8

# Metadata server (the `server` binary; reuses GROBID_URL above). Serves
# structured Field-schema metadata for upload_interface's autocomplete form:
# PUT /metadata/{sha256} runs GROBID + the domain transform and returns the
# result (transient, not persisted); GET /metadata/{sha256} retrieves a
# previously-*saved* result; PATCH /metadata/{sha256} is the only endpoint
# that persists anything, saving the user's edited fields. Never writes to
# TypeDB or Qdrant -- those only happen via the batch pipeline above.
METADATA_SERVER_ADDRESS=0.0.0.0:8081
METADATA_DIR=./metadata
# "app-name:key,other-app:key" pairs authorizing machine clients. The
# browser instead authenticates via the Authentik session cookie below --
# see get_current_user_or_api_key-equivalent AuthorizedCaller.
METADATA_API_KEYS=

# Authentik OAuth2/OIDC (upload_interface's frontend calls this server's
# /metadata endpoints directly, so it needs its own login flow, mirroring
# studio's dual-auth setup). Requires its own Authentik application/client
# registration, separate from studio's.
METADATA_SERVER_BASE_URL=http://localhost:8081
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_DISCOVERY_URL=
OAUTH_LOGOUT_URL=
SESSION_SECRET=
# upload_interface's origin; the CORS-allowed origin and where the browser
# lands after logging in.
FRONTEND_URL=http://localhost:5173
