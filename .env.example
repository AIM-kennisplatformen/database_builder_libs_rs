PDF_SOURCE=./papers/pdfs
TEI_XML_DIR=./papers/tei
JSON_DIR=./papers/json

# Grobid
GROBID_URL=http://localhost:8070

# TypeDB
TYPEDB_ADDRESS=localhost:1729
TYPEDB_DATABASE=kp-scepa
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=password
TYPEDB_TLS=false
TYPEDB_WIPE_DATABASE=false

# ROR (Research Organization Registry, for institution ror-id resolution)
ROR_HOST=https://api.ror.org

# Qdrant
QDRANT_URL=http://localhost:6334
QDRANT_COLLECTION=kp-scepa
QDRANT_VECTOR_SIZE=4096
QDRANT_API_KEY=
QDRANT_WIPE_COLLECTION=false

# Embedding
OPENAI_HOST=https://api.tokenfactory.nebius.com/v1/
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# BATCH
PARALLELISM=8
WORKER_THREADS=8
